datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Customer {
  id           String   @id @default(uuid())
  customerCode String   @unique // e.g. "A102"
  name         String
  email        String
  phone        String
  address      String?
  orders       Order[]
  createdAt    DateTime @default(now())
}

model Employee {
  id             String         @id @default(uuid())
  name           String
  role           String         // e.g. "Admin", "Marketer", "Designer", "Installer"
  referredLeads  Lead[]         @relation("EmployeeReferrals")
  referredOrders Order[]        @relation("OrderReferrer")
  assignedJobs   Order[]        @relation("EmployeeAssignments")
  payoutRewards  PayoutReward[]
  createdAt      DateTime       @default(now())
}

model Lead {
  id           String   @id @default(uuid()) // YYYY-MM-CUST-SEQ format stored as string primary key
  date         DateTime @default(now())
  projectName  String
  customerName String
  email        String
  phone        String
  source       String   // e.g. "Website", "Reference", "Google Maps"
  budget       Float
  status       String   @default("Enquired") // e.g. "Enquired", "Quotation"
  
  referredById String
  referredBy   Employee @relation("EmployeeReferrals", fields: [referredById], references: [id])
}

model Order {
  id                   String            @id // e.g. "2026-06-A102-001"
  date                 DateTime          @default(now())
  projectName          String
  status               String            // e.g. "Site visit", "Design", "Production", "Installation", "Completed"
  budget               Float
  isUrgent             Boolean           @default(false)
  designApprovedAt     DateTime?
  installationSchedule Json?             // e.g. { date: "2026-06-15", time: "10:00 AM - 12:00 PM" }
  
  customerCode         String
  customer             Customer          @relation(fields: [customerCode], references: [customerCode])
  
  referredById         String?
  referredBy           Employee?         @relation("OrderReferrer", fields: [referredById], references: [id])
  
  assignedEmployees    Employee[]        @relation("EmployeeAssignments")
  siteMeasurements     SiteMeasurement[]
  quotes               Quote[]
  designVersions       DesignVersion[]
  supportTickets       SupportTicket[]
  payoutRewards        PayoutReward[]
  createdAt            DateTime          @default(now())
}

model SiteMeasurement {
  id           String   @id @default(uuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id])
  height       Float    // ft
  width        Float    // ft
  depth        Float    // in
  backdropType String   // e.g. "Concrete wall", "Glass facade"
  notes        String?
  mediaUrls    Json?    // Array of mock file paths: ["site_photo.jpg", "wiring_access.jpg"]
  createdAt    DateTime @default(now())
}

model Quote {
  id             String   @id @default(uuid())
  orderId        String
  order          Order    @relation(fields: [orderId], references: [id])
  variantName    String   // e.g. "Good", "Better", "Best"
  specifications String
  cost           Float
  isSelected     Boolean  @default(false)
  paymentSplits  Json     // e.g. { advance: 40, design: 40, completion: 20 }
  createdAt      DateTime @default(now())
}

model DesignVersion {
  id         String          @id @default(uuid())
  orderId    String
  order      Order           @relation(fields: [orderId], references: [id])
  version    String          // e.g. "v1.0", "v2.0"
  fileName   String          // e.g. "logo_glow_v1.psd"
  uploadedBy String
  timestamp  DateTime        @default(now())
  status     String          // e.g. "Pending Feedback", "Approved", "Rejected"
  comments   DesignComment[]
}

model DesignComment {
  id              String        @id @default(uuid())
  designVersionId String
  designVersion   DesignVersion @relation(fields: [designVersionId], references: [id])
  text            String
  x               Float         // Position percentages: 0 to 100
  y               Float         // Position percentages: 0 to 100
  author          String        // e.g. "Customer", "Designer Priya"
  timestamp       DateTime      @default(now())
}

model SupportTicket {
  id           String   @id @default(uuid()) // e.g. "TCK-402"
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id])
  customerName String
  issueType    String   // e.g. "LED flickering"
  description  String
  status       String   @default("Open") // e.g. "Open", "Resolved"
  stars        Int?     // Star rating: 1 to 5
  date         DateTime @default(now())
}

model PayoutReward {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id])
  amount     Float
  type       String   // e.g. "LeadReferral", "ProjectBonus"
  date       DateTime @default(now())
}
